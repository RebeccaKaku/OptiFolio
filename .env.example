# OptiFolio Environment Variables
# Copy this file to .env (or set in your shell) for local development.

# ── Server ──────────────────────────────────────────────────────────
# CORS origins (comma-separated). Default: localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ────────────────────────────────────────────────────────
# Portfolio book database path. Default: local/portfolio_book.sqlite
# OPTIFOLIO_DB_PATH=

# ── Portfolio ───────────────────────────────────────────────────────
# Custom portfolio YAML path. Default: local/portfolio.yaml → config/portfolio.yaml
# OPTIFOLIO_PORTFOLIO_PATH=

# ── Proxy (for akshare/yfinance) ────────────────────────────────────
# Set if your network requires a proxy to reach financial data sources.
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
# NO_PROXY=localhost,127.0.0.1,::1

# ── Logging ─────────────────────────────────────────────────────────
# Python logging level. Default: INFO
# LOG_LEVEL=DEBUG
